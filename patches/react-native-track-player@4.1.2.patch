+    @MainThread
+    private fun getExoPlayer(): ExoPlayer? {
+        try {
+            var cls: Class<*>? = player.javaClass
+            while (cls != null) {
+                try {
+                    val field = cls.getDeclaredField("exoPlayer")
+                    field.isAccessible = true
+                    return field.get(player) as? ExoPlayer
+                } catch (_: NoSuchFieldException) {
+                    cls = cls.superclass
+                }
+            }
+        } catch (error: Exception) {
+            Timber.e(error, "Failed to access ExoPlayer via reflection")
+        }
+
+        return null
+    }
+
+    @MainThread
+    fun setPitch(pitch: Float) {
